{
  "version": "2026-03-09",
  "apiBasePath": "/api/v1",
  "feature": "cash-settlement-submit",
  "notes": [
    "All amounts are integer cents.",
    "All IDs are UUID strings.",
    "Group frontend must not implement settlement delete/reset actions."
  ],
  "backlogAdminPortal": {
    "status": "future",
    "doNotImplementInGroupFrontend": true,
    "futureAdminEndpoint": {
      "method": "DELETE",
      "path": "/api/v1/admin/groups/{groupId}/settlements",
      "headers": {
        "X-Admin-Portal-Token": "<admin token>"
      },
      "response": {
        "groupId": "uuid",
        "deletedSettlementCount": 0,
        "releasedExpenseCount": 0
      }
    }
  },
  "createSettlementRules": [
    "expenseIds is required and cannot be empty.",
    "amountCents must equal the sum of amount_cents for selected expenseIds."
  ],
  "endpoints": [
    {
      "name": "CreateSettlement",
      "method": "POST",
      "path": "/groups/{groupId}/settlements",
      "requestBody": {
        "fromUserId": "uuid",
        "toUserId": "uuid",
        "amountCents": 5300,
        "expenseIds": [
          "f3b89cb8-6b73-4e8d-bfb5-9915d3f6e312"
        ],
        "note": "Cash reimbursement",
        "settledAt": "2026-03-09T00:00:00-05:00"
      },
      "successResponse": {
        "settlementId": "7c4c29bf-1838-4b2b-bb0b-8d3f5db5956a",
        "settlement": {
          "id": "7c4c29bf-1838-4b2b-bb0b-8d3f5db5956a",
          "groupId": "2ec9fc55-a4f0-47ef-9607-b0bd5cf47de7",
          "fromUserId": "ca1f7d57-f5bb-4fa4-ac89-9dc26f92be59",
          "fromUserName": "Julio",
          "toUserId": "421fda19-0e36-4aaf-a3c9-bc8fd326ad9f",
          "toUserName": "Julio C. Mendoza",
          "amountCents": 5300,
          "note": "Cash reimbursement",
          "settledAt": "2026-03-09T00:00:00.0000000-05:00",
          "expenseIds": [
            "f3b89cb8-6b73-4e8d-bfb5-9915d3f6e312"
          ]
        }
      }
    },
    {
      "name": "ListGroupSettlements",
      "method": "GET",
      "path": "/groups/{groupId}/settlements"
    },
    {
      "name": "GetSettlement",
      "method": "GET",
      "path": "/settlements/{settlementId}"
    },
    {
      "name": "ListUserSettlements",
      "method": "GET",
      "path": "/users/{userId}/settlements"
    },
    {
      "name": "GroupDetailsForSettlementTable",
      "method": "GET",
      "path": "/groups/{groupId}/details",
      "responseAdditions": {
        "expenses": {
          "addedFields": {
            "settlementId": "uuid|null",
            "isSettled": "boolean"
          }
        },
        "settlements": {
          "itemFields": {
            "id": "uuid",
            "groupId": "uuid",
            "fromUserId": "uuid",
            "fromUserName": "string",
            "toUserId": "uuid",
            "toUserName": "string",
            "amountCents": "integer",
            "note": "string|null",
            "settledAt": "date-time",
            "expenseIds": "uuid[]"
          }
        },
        "settlementSuggestions": {
          "itemFields": {
            "fromUserId": "uuid",
            "fromUserName": "string",
            "toUserId": "uuid",
            "toUserName": "string",
            "amountCents": "integer"
          }
        },
        "summary": {
          "addedFields": {
            "settlementCount": "integer",
            "totalSettlementAmountCents": "integer"
          }
        }
      }
    }
  ]
}
